/* ================== VARIABLES Y UTILIDADES ================== */
:root {
  --color-primary: #2563eb;
  --color-primary-dark: #1d4ed8;
  --color-success: #10b981;
  --color-warning: #f59e0b;
  --color-danger: #ef4444;
  --color-bg: #fafafa;
  --color-bg-secondary: #ffffff;
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-border: #e5e7eb;
  --color-border-light: #f3f4f6;
  --color-accent: #f97316;
  --color-accent-light: #fed7aa;
}

/* ================== CONTAINER PRINCIPAL ================== */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-top: 3.5rem;
  display: flex;
  flex-direction: column;
}

/* ================== HEADER FIXED ================== */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 3.5rem;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--color-border);
  z-index: 50;
  transition: all 200ms ease;
}

.header.headerScrolled {
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.headerContent {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1rem;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 1rem;
}

@media (min-width: 768px) {
  .headerContent {
    padding: 0 1.5rem;
  }
}

.headerBackButton {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  color: var(--color-text-primary);
  cursor: pointer;
  font-size: 1.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
  flex-shrink: 0;
}

.headerBackButton:hover {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
  transform: scale(1.05);
}

.headerTitle {
  flex: 1;
  min-width: 0;
}

.headerTitle h1 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.headerRating {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  color: var(--color-text-secondary);
  margin-top: 0.25rem;
}

.headerRating svg {
  width: 0.875rem;
  height: 0.875rem;
  color: #fbbf24;
}

.headerReviews {
  color: var(--color-text-tertiary);
  margin-left: 0.25rem;
}

.headerActions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.headerActionButton {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  color: var(--color-text-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
}

.headerActionButton:hover {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
  transform: scale(1.05);
}

.favoriteActive {
  fill: #ef4444 !important;
  color: #ef4444 !important;
}

/* ================== HERO SECTION ================== */
.heroSection {
  width: 100%;
  height: 300px;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
}

@media (min-width: 768px) {
  .heroSection {
    height: 400px;
  }
}

.heroCarousel {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.heroImage {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.heroOverlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.3) 50%,
    rgba(0, 0, 0, 0.6) 100%
  );
  display: flex;
  align-items: flex-end;
  padding: 2rem 1rem;
}

@media (min-width: 768px) {
  .heroOverlay {
    padding: 3rem;
  }
}

.heroContent {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-self: flex-end;
}

.heroRating {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.stars {
  display: flex;
  gap: 0.25rem;
}

.stars svg {
  width: 1.25rem;
  height: 1.25rem;
  color: rgba(255, 255, 255, 0.3);
}

.starFilled {
  color: #fbbf24 !important;
  fill: currentColor;
}

.ratingText {
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.875rem;
  font-weight: 500;
}

.heroStatus {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.statusBadge {
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 600;
  color: white;
  background: rgba(0, 0, 0, 0.3);
}

.statusOpen {
  background: rgba(16, 185, 129, 0.4) !important;
}

.statusClosed {
  background: rgba(239, 68, 68, 0.4) !important;
}

.horaActual {
  color: white;
  font-size: 0.875rem;
  font-weight: 500;
}

.heroCTA {
  align-self: flex-start;
  padding: 0.875rem 1.75rem;
  background: var(--color-accent);
  color: white;
  border: none;
  border-radius: 0.5rem;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 200ms ease;
  box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
}

.heroCTA:hover {
  background: #ea580c;
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(249, 115, 22, 0.4);
}

.heroCTA:active {
  transform: translateY(0);
}

/* ================== CONTENIDO PRINCIPAL ================== */
.contentArea {
  flex: 1;
  max-width: 1400px;
  width: 100%;
  margin: 0 auto;
  padding: 2rem 1rem;
}

@media (min-width: 768px) {
  .contentArea {
    padding: 2rem 1.5rem;
  }
}

/* ================== TABS ================== */
.tabs {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 2rem;
  border-bottom: 1px solid var(--color-border);
  overflow-x: auto;
  scroll-behavior: smooth;
}

.tabButton {
  padding: 1rem;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  color: var(--color-text-secondary);
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: all 200ms ease;
  position: relative;
}

.tabButton:hover {
  color: var(--color-text-primary);
}

.tabActive {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
}

.tabContent {
  animation: fadeIn 200ms ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ================== SECCIONES ================== */
.section {
  margin-bottom: 3rem;
}

.sectionTitle {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 1.5rem;
}

/* ================== INFO CONTACTO ================== */
.infoGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.infoCard {
  display: flex;
  gap: 1rem;
  padding: 1.25rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  text-decoration: none;
  color: inherit;
  transition: all 200ms ease;
  cursor: pointer;
}

.infoCard:hover {
  border-color: var(--color-primary);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  transform: translateY(-2px);
}

.infoIcon {
  flex-shrink: 0;
  width: 3rem;
  height: 3rem;
  background: var(--color-accent-light);
  border-radius: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-accent);
}

.infoContent {
  flex: 1;
  min-width: 0;
}

.infoLabel {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.25rem;
}

.infoValue {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 0.25rem;
}

.infoMeta {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}

/* ================== HORARIOS ================== */
.scheduleGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 1rem;
}

.scheduleDay {
  padding: 1.25rem;
  background: var(--color-bg-secondary);
  border: 2px solid var(--color-border);
  border-radius: 0.75rem;
  text-align: center;
  transition: all 200ms ease;
}

.scheduleDayToday {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.05), rgba(37, 99, 235, 0.02));
}

.scheduleDayClosed {
  opacity: 0.6;
  background: var(--color-border-light);
}

.scheduleDayName {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}

.scheduleTime {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ================== FAQ ================== */
.faqList {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.faqItem {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  overflow: hidden;
}

.faqButton {
  width: 100%;
  padding: 1.25rem;
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  transition: all 200ms ease;
}

.faqButton:hover {
  background: var(--color-border-light);
}

.faqQuestion {
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: left;
}

.faqAnswer {
  padding: 0 1.25rem 1.25rem 1.25rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
  border-top: 1px solid var(--color-border);
}

/* ================== FILTROS ================== */
.filterButtons,
.resenaFilterButtons {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 2rem;
  overflow-x: auto;
  scroll-behavior: smooth;
  padding-bottom: 0.5rem;
}

.filterButton {
  padding: 0.625rem 1rem;
  background: var(--color-bg-secondary);
  border: 2px solid var(--color-border);
  border-radius: 9999px;
  color: var(--color-text-primary);
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  white-space: nowrap;
  transition: all 200ms ease;
}

.filterButton:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.filterButtonActive {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: white;
}

/* ================== SERVICIOS GRID ================== */
.serviciosGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .serviciosGrid {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
}

.servicioCard {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  overflow: hidden;
  cursor: pointer;
  transition: all 200ms ease;
  display: flex;
  flex-direction: column;
}

.servicioCard:hover {
  border-color: var(--color-primary);
  box-shadow: 0 8px 16px rgba(37, 99, 235, 0.15);
  transform: translateY(-4px);
}

.servicioImagen {
  width: 100%;
  height: 150px;
  overflow: hidden;
  background: var(--color-border-light);
}

.servicioImagen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 200ms ease;
}

.servicioCard:hover .servicioImagen img {
  transform: scale(1.05);
}

.servicioContent {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.servicioNombre {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}

.servicioDescripcion {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  margin: 0;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.servicioInfo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.75rem;
  border-top: 1px solid var(--color-border);
  margin-top: auto;
}

.servicioPrecio {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-accent);
}

.servicioDuracion {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  background: var(--color-border-light);
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
}

/* ================== BARBEROS GRID ================== */
.barberosGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .barberosGrid {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
}

.barberoCard {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: all 200ms ease;
}

.barberoCard:hover {
  border-color: var(--color-primary);
  box-shadow: 0 8px 16px rgba(37, 99, 235, 0.15);
  transform: translateY(-4px);
}

.barberoImagen {
  width: 100%;
  height: 180px;
  overflow: hidden;
  background: var(--color-border-light);
}

.barberoImagen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.barberoBg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 2.5rem;
  font-weight: 700;
}

.barberoContent {
  padding: 1rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.barberoNombre {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}

.barberoEspecialidad {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  margin: 0;
}

.barberoRating {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.ratingValue {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.barberoButton {
  padding: 0.75rem;
  background: var(--color-primary);
  color: white;
  border: none;
  border-radius: 0.5rem;
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all 200ms ease;
  margin-top: auto;
}

.barberoButton:hover {
  background: var(--color-primary-dark);
  transform: scale(1.02);
}

/* ================== RESEÑAS ================== */
.resenasList {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.resenaCard {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1.5rem;
  transition: all 200ms ease;
}

.resenaCard:hover {
  border-color: var(--color-primary);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
}

.resenaHeader {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1rem;
  gap: 1rem;
}

.resenaAutor {
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
}

.resenaAvatar {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

.resenaAutorInfo {
  display: flex;
  flex-direction: column;
}

.resenaAutorNombre {
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
  font-size: 1rem;
}

.resenaFecha {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  margin: 0;
}

.resenaRating {
  font-size: 1rem;
  white-space: nowrap;
}

.resenaTexto {
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin: 0;
  font-size: 0.95rem;
}

/* ================== EMPTY STATE ================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rem 1rem;
  color: var(--color-text-tertiary);
  text-align: center;
}

.emptyState svg {
  margin-bottom: 1rem;
}

.emptyState p {
  font-size: 1rem;
  margin: 0;
}

/* ================== FOOTER CTA ================== */
.footerCTA {
  padding: 1rem;
  background: var(--color-bg-secondary);
  border-top: 1px solid var(--color-border);
  position: sticky;
  bottom: 0;
  z-index: 40;
}

@media (min-width: 768px) {
  .footerCTA {
    padding: 1.5rem;
  }
}

.primaryButton {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem;
  background: linear-gradient(135deg, var(--color-accent), #ea580c);
  color: white;
  border: none;
  border-radius: 0.5rem;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: all 200ms ease;
  box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
}

.primaryButton:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(249, 115, 22, 0.4);
}

.primaryButton:active {
  transform: translateY(0);
}

/* ================== LOADING ================== */
.loadingContainer,
.errorContainer {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 2rem;
  color: var(--color-text-secondary);
}

.spinner {
  width: 3rem;
  height: 3rem;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.errorContainer {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 2rem;
  max-width: 400px;
  text-align: center;
}

.errorContainer p {
  font-size: 1.125rem;
  margin-bottom: 1.5rem;
}

/* ================== RESPONSIVE ================== */
@media (max-width: 640px) {
  .headerTitle h1 {
    font-size: 0.875rem;
  }

  .sectionTitle {
    font-size: 1.25rem;
  }

  .serviciosGrid,
  .barberosGrid {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  }

  .tabs {
    margin-bottom: 1.5rem;
  }

  .tabButton {
    padding: 0.75rem;
    font-size: 0.875rem;
  }
}
